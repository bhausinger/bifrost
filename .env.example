# Campaign Manager v2 — Environment Configuration
# Copy this file to .env and fill in your values.

# Supabase (get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Scraper API (optional — defaults to localhost:9999)
# VITE_SCRAPER_URL=http://localhost:9999
